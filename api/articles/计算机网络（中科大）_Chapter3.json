7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-97.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-91.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-98.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-90.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-117.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-119.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-115.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-118.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-116.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-109.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-108.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-113.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-107.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-111.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-114.png"],"content":"<h1 id=\"第三章-传输层\"><a href=\"#第三章-传输层\" class=\"headerlink\" title=\"第三章 传输层\"></a>第三章 传输层</h1><p>在网络通信中，传输层是连接网络层与应用层之间的桥梁。它不仅负责实现端到端的进程通信，更要保障数据传输的可靠性、有序性与效率。无论是浏览网页、传输文件，还是观看视频、进行在线游戏，传输层都发挥着至关重要的作用。</p>\n<p>本章将深入剖析传输层的核心机制，包括多路复用与解复用、UDP与TCP协议的结构与特点、可靠数据传输的设计原理、流量控制、连接管理，以及拥塞控制的策略与实现。此外，还将介绍经典的滑动窗口协议和TCP拥塞控制算法，帮助读者从理论与实践两方面全面掌握传输层的工作原理与技术细节。</p>\n<span id=\"more\"></span>\n\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/Cover.png\"></p>\n<h2 id=\"3-1-传输层服务\"><a href=\"#3-1-传输层服务\" class=\"headerlink\" title=\"3.1 传输层服务\"></a>3.1 传输层服务</h2><p>网络层提供的是主机之间的逻辑通信</p>\n<p>传输层向上层提供进程与进程之间，以message为单位的逻辑的通信。</p>\n<p>并对网络层的服务进行加强。</p>\n<h3 id=\"Internet传输层协议\"><a href=\"#Internet传输层协议\" class=\"headerlink\" title=\"Internet传输层协议\"></a>Internet传输层协议</h3><p>可靠的，保序的传输 TCP</p>\n<ul>\n<li><p>多路复用、解复用</p>\n</li>\n<li><p>拥塞控制</p>\n</li>\n<li><p>流量控制</p>\n</li>\n<li><p>建立连接</p>\n</li>\n</ul>\n<p>不可靠、不保序的传输 UDP</p>\n<ul>\n<li><p>多路复用、解复用</p>\n</li>\n<li><p>没有为尽力而为的IP服务添加更多的其他额外服务</p>\n</li>\n</ul>\n<p>都不提供的服务</p>\n<ul>\n<li><p>延时保证</p>\n</li>\n<li><p>带宽保证</p>\n</li>\n</ul>\n<h2 id=\"3-2-多路复用与解复用\"><a href=\"#3-2-多路复用与解复用\" class=\"headerlink\" title=\"3.2 多路复用与解复用\"></a>3.2 多路复用与解复用</h2><p>在发送方主机多路复用</p>\n<p>从多个socket接收来自多个进程的报文，根据socket对应的IP地址和端口号等信息对报文段用头部加以封装（该头部信息用于之后的解复用）</p>\n<p>在接收方主机多路解复用</p>\n<p>根据报文段的头部信息中的IP和端口号将接收到的报文段发给正确的socket（和对应的应用进程）</p>\n<h3 id=\"多路解复用工作原理\"><a href=\"#多路解复用工作原理\" class=\"headerlink\" title=\"多路解复用工作原理\"></a>多路解复用工作原理</h3><p>解复用作用：TCP或者UDP实体采用哪些信息，将报文段的数据部分交给正确的socket，从而交给正确的进程</p>\n<p>主机收到IP数据报</p>\n<p>主机联合使用IP地址和socket将报文段发给合适的socket</p>\n<h3 id=\"UDP多路解复用\"><a href=\"#UDP多路解复用\" class=\"headerlink\" title=\"UDP多路解复用\"></a>UDP多路解复用</h3><p>创建socket</p>\n<p>在接收端，UDP socket用二元组标识（接收端的IP地址、端口号）</p>\n<p>当主机收到UDP报文段</p>\n<ul>\n<li><p>检查报文段的目标端口号</p>\n</li>\n<li><p>用该端口号将报文段定位给socket</p>\n</li>\n</ul>\n<p>如果两个不同源IP地址、源端口的数据报，但是有相同的目标地址和目标端口，则被定位到相同的socket</p>\n<h4 id=\"例子\"><a href=\"#例子\" class=\"headerlink\" title=\"例子\"></a>例子</h4><p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-46.png\"></p>\n<h3 id=\"TCP多路复用与解复用\"><a href=\"#TCP多路复用与解复用\" class=\"headerlink\" title=\"TCP多路复用与解复用\"></a>TCP多路复用与解复用</h3><p>TCP socket用四元组标识（源IP，源端口，目标IP，目标端口）</p>\n<p>服务器能够在一个TCP端口上同时支持多个TCPsocket，每个socket都由四元组标识</p>\n<p>解复用则是接收主机通过这个四元组定位到合适的socket</p>\n<h4 id=\"例子-1\"><a href=\"#例子-1\" class=\"headerlink\" title=\"例子\"></a>例子</h4><p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-52.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-72.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-74.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-71.png\"></p>\n<h2 id=\"3-3-无连接传输-UDP\"><a href=\"#3-3-无连接传输-UDP\" class=\"headerlink\" title=\"3.3 无连接传输 UDP\"></a>3.3 无连接传输 UDP</h2><p>User Datagram Protocol</p>\n<p>“尽力而为的服务”，报文段可能丢失或乱序</p>\n<p>无连接：UDP发送端和接收端之间没有握手，每个UDP报文都被独立地处理</p>\n<p>UDP常用于：流媒体、DNS、SNMP</p>\n<p>如果要在UDP上实现可靠传输，则需要在应用层上增加可靠性，或者应用特定的差错恢复</p>\n<h3 id=\"UDP的数据报格式\"><a href=\"#UDP的数据报格式\" class=\"headerlink\" title=\"UDP的数据报格式\"></a>UDP的数据报格式</h3><p>8Byte的头部包括：2Byte源端口号，2Byte目的端口号，2Byte长度，2Byte校验和</p>\n<p>和应用程序数据（报文）</p>\n<h3 id=\"为什么要有UDP？\"><a href=\"#为什么要有UDP？\" class=\"headerlink\" title=\"为什么要有UDP？\"></a>为什么要有UDP？</h3><p>不建立连接</p>\n<p>简单：发送端和接收端没有连接状态</p>\n<p>头部很小（开销小）</p>\n<p>无拥塞控制和流量控制：UDP可以以尽可能快的发送报文段</p>\n<p>应用到传输层的效率和主机到网络的速率一样快</p>\n<h3 id=\"UDP校验和\"><a href=\"#UDP校验和\" class=\"headerlink\" title=\"UDP校验和\"></a>UDP校验和</h3><p>用于检测在被传输报文段中的差错</p>\n<h4 id=\"发送方\"><a href=\"#发送方\" class=\"headerlink\" title=\"发送方\"></a>发送方</h4><p>将报文段的内容视为16bit的整数</p>\n<p>校验和:报文段的加法和具体细节详见例子</p>\n<p>发送方将校验和放在UDP的校验和字段</p>\n<h4 id=\"接收方\"><a href=\"#接收方\" class=\"headerlink\" title=\"接收方\"></a>接收方</h4><p>计算接收到的报文段的校验和</p>\n<p>检查计算出的校验和与报文中的校验和是否相等</p>\n<p>不相等-&gt;检测到差错</p>\n<p>相等-&gt;没有检测到差错,但也有可能出现差错(残存错误:出现差错了,但是校验和又恰算出来是对的)</p>\n<h4 id=\"例子-2\"><a href=\"#例子-2\" class=\"headerlink\" title=\"例子\"></a>例子</h4><p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-70.png\"></p>\n<h2 id=\"3-4-可靠数据传输的原理\"><a href=\"#3-4-可靠数据传输的原理\" class=\"headerlink\" title=\"3.4 可靠数据传输的原理\"></a>3.4 可靠数据传输的原理</h2><p>RDT在应用层、传输层和数据链路层都很重要,是网络TOP10的问题</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-69.png\"></p>\n<p>在下层提供的服务不可靠的情况下,本层协议如何通过一些时空资源的安排,向上层提供可靠的服务</p>\n<h3 id=\"可靠数据传输-问题描述\"><a href=\"#可靠数据传输-问题描述\" class=\"headerlink\" title=\"可靠数据传输: 问题描述\"></a>可靠数据传输: 问题描述</h3><ul>\n<li><p>渐进式地开发可靠数据传输协议的发送方和接收方</p>\n</li>\n<li><p>只考虑单向数据传输(但是控制信息是双向流动的)</p>\n</li>\n<li><p>用FSM(有限状态机)来描述发送方和接收方</p>\n</li>\n</ul>\n<h3 id=\"RDT1-0-在可靠信道上的可靠数据传输\"><a href=\"#RDT1-0-在可靠信道上的可靠数据传输\" class=\"headerlink\" title=\"RDT1.0 在可靠信道上的可靠数据传输\"></a>RDT1.0 在可靠信道上的可靠数据传输</h3><p>下层信道是完全可靠的</p>\n<ul>\n<li><p>没有bit出错</p>\n</li>\n<li><p>没有分组丢失</p>\n</li>\n</ul>\n<p>发送方和接收方的FSM</p>\n<ul>\n<li><p>发送方将数据发送到下层信道</p>\n</li>\n<li><p>接收方从下层信道接收数据</p>\n</li>\n</ul>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-66.png\"></p>\n<p>所以RDT1.0只有封装和解封装的作用</p>\n<h3 id=\"RDT2-0-具有bit差错的信道\"><a href=\"#RDT2-0-具有bit差错的信道\" class=\"headerlink\" title=\"RDT2.0 具有bit差错的信道\"></a>RDT2.0 具有bit差错的信道</h3><p>下层信道可能会出错:将分组中的翻转</p>\n<p>问题:怎样从差错中恢复?</p>\n<ul>\n<li><p>确认(ACK): 接收方显式地告诉发送方分组已被正确接收</p>\n</li>\n<li><p>否定确认(NAK): 接收方显式地告诉发送方分组发生了差错, 发送方收到NAK后重传分组</p>\n</li>\n<li><p>是一种停止-等待协议：发送方发送一个分组，然后等待接收方的应答</p>\n</li>\n</ul>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-67.png\"></p>\n<p>RDT2.0的运行</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-73.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-65.png\"></p>\n<h4 id=\"RDT2-1-引入序号机制\"><a href=\"#RDT2-1-引入序号机制\" class=\"headerlink\" title=\"RDT2.1 引入序号机制\"></a>RDT2.1 引入序号机制</h4><p>在RDT2.0中, 如果ACK&#x2F;NAK出错呢?</p>\n<ul>\n<li>发送方不知道接收方发生了什么。重传可能重复，不重传可能死锁或出错</li>\n</ul>\n<p>因此我们引入了新的机制：序号</p>\n<p>发送方收到ACK时，发送P1，收到非ACK时，重放P0</p>\n<p>接收方通过序号对比，如果没出错或者重复，则再次发送ACK，当且仅当出错时发送NAK</p>\n<p>FSM：</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-62.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-68.png\"></p>\n<p>发送方：</p>\n<ul>\n<li><p>在分组中加入序号</p>\n</li>\n<li><p>两个序号（0，1）就足够了，一次只发送一个未经确认的分组</p>\n</li>\n<li><p>必须检测ACK&#x2F;NAK是否出错</p>\n</li>\n<li><p>状态数变成了两倍</p>\n</li>\n</ul>\n<p>接收方：</p>\n<ul>\n<li>必须检测接收到的分组是否重复，状态会指示希望接收到的分组序号是0还是1</li>\n</ul>\n<p>RDT 2.1的运行</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-60.png\"></p>\n<h4 id=\"RDT2-2-无NAK的协议\"><a href=\"#RDT2-2-无NAK的协议\" class=\"headerlink\" title=\"RDT2.2 无NAK的协议\"></a>RDT2.2 无NAK的协议</h4><p>功能同RDT2.1，但只使用ACK（ACK要编号）</p>\n<p>当收到重复的ACK时，发送方采用与收到NAK采取相同的动作：重传当前分组</p>\n<p>ACK0 &#x3D;&#x3D; NAK1，以此类推，所以可以去除NAK</p>\n<p>这样可以为之后一次发送多个数据单位做准备：</p>\n<ul>\n<li><p>一次能够发送多个</p>\n</li>\n<li><p>每一个应答都有ACK，NAK的话会很麻烦</p>\n</li>\n<li><p>确认信息减少一半，协议处理简单</p>\n</li>\n</ul>\n<p>FSM：</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-63.png\"></p>\n<p>RDT2.2的运行</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-64.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-61.png\"></p>\n<p>此处的ACK序号只有0和1交替使用。Pkt n出错时，应该返回Pkt n-1所对应的ACK。</p>\n<p>如：Pkt2出错时，应该返回ACK1。Pkt3出错时，应该返回ACK0。</p>\n<h3 id=\"RDT3-0-具有比特差错和分组丢失的信道\"><a href=\"#RDT3-0-具有比特差错和分组丢失的信道\" class=\"headerlink\" title=\"RDT3.0 具有比特差错和分组丢失的信道\"></a>RDT3.0 具有比特差错和分组丢失的信道</h3><p>新的假设：下层信道可能会丢失分组（Pkt或ACK）</p>\n<ul>\n<li>会死锁（Pkt0丢失，接收方需要Pkt0来发送ACK，而发送方需要ACK来发送下一个Pkt）</li>\n</ul>\n<p>因此引入超时重传机制</p>\n<p>发送方发出Pkt后启动超时定时器</p>\n<p>发送方等待ACK一段合理的时间</p>\n<p>发送端超时重传：如果到时没收到ACK，则重传</p>\n<p>如果ACK丢失或者分组只是被延迟了，也会重传，但是利用序列号已经可以解决重复的问题</p>\n<p>FSM：</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-88.png\"></p>\n<p>RDT3.0的运行</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-87.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-86.png\"></p>\n<p>过早的超时（延迟的ACK）也能够正常工作；但是效率较低，一半的分组和确认是重复的。因此设置一个合理的超时时间是比较重要的</p>\n<h4 id=\"RDT3-0的性能\"><a href=\"#RDT3-0的性能\" class=\"headerlink\" title=\"RDT3.0的性能\"></a>RDT3.0的性能</h4><p>rdt3.0可以工作，但链路容量比较大的情况下，性能很差。</p>\n<p>链路容量比较大，一次发一个PDU不能够充分利用链路的传输能力，利用率很差</p>\n<p>例子：</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-85.png\"></p>\n<p>因此这样的网络协议本身显著地限制了物理资源的利用。</p>\n<h3 id=\"流水线协议\"><a href=\"#流水线协议\" class=\"headerlink\" title=\"流水线协议\"></a>流水线协议</h3><p>停-等协议VS流水线协议</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-84.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-81.png\"></p>\n<p>流水线：允许发送方在未得到对方确认的情况下一次发送多个分组</p>\n<ul>\n<li><p>必须增加序号的范围：用多个bit表示分组的序号</p>\n</li>\n<li><p>在发送方&#x2F;接收方要设有缓冲区</p>\n<ul>\n<li><p>发送方缓冲：未得到确认，可能需要重传</p>\n</li>\n<li><p>接收方缓冲：上层用户取用数据的速率≠接收数据的速率。接收到的数据可能乱序，需要排序后交付</p>\n</li>\n</ul>\n</li>\n<li><p>两种通用的流水线协议：回退N步(GBN: Go Back N)和选择重传(SR: Select Repeat)</p>\n</li>\n</ul>\n<h4 id=\"滑动窗口（slide-window）协议\"><a href=\"#滑动窗口（slide-window）协议\" class=\"headerlink\" title=\"滑动窗口（slide window）协议\"></a>滑动窗口（slide window）协议</h4><table>\n<thead>\n<tr>\n<th>发送窗口SW</th>\n<th>接收窗口RW</th>\n<th>协议</th>\n</tr>\n</thead>\n<tbody><tr>\n<td>&#x3D;&#x3D;1</td>\n<td>&#x3D;&#x3D;1</td>\n<td>停止等待协议</td>\n</tr>\n<tr>\n<td>&gt;1</td>\n<td>&#x3D;&#x3D;1</td>\n<td>GBN</td>\n</tr>\n<tr>\n<td>&gt;1</td>\n<td>&gt;1</td>\n<td>SR</td>\n</tr>\n</tbody></table>\n<p>落入发送缓冲区的分组可以直接发送</p>\n<p>发送缓冲区的大小:一次最多可以发送多少个未经确认的分组</p>\n<p>只有得到确认的分组才能从缓冲区之中删除</p>\n<p>发送窗口: 发送缓冲区的一个范围，已发送但是未确认的分组</p>\n<p>发送窗口的大小&lt;&#x3D;发送缓冲区的大小</p>\n<p>一开始：没有发送任何一个分组，size &#x3D;&#x3D; 0</p>\n<p>每发送一个分组，滑动窗口的前沿向前滑动一格。最多滑动到窗口大小等于缓冲区的大小最大值。</p>\n<p>如果后沿所指的分组被确认，则后沿向前滑动。</p>\n<p>接收窗口&#x3D;接收缓冲区</p>\n<p>接收窗口可以用于控制哪些分组可以被接收：</p>\n<ul>\n<li><p>只有收到分组序号落入接收窗口内才允许接收</p>\n</li>\n<li><p>在接收窗口外则丢弃</p>\n</li>\n</ul>\n<p>GBN协议 size &#x3D;&#x3D; 1只能顺序接收，且只能发送连续收到的最大的分组的确认</p>\n<p>SR协议 size &gt; 1则可以乱序接收，哪一个分组到来就发哪个一个分组的确认</p>\n<p>滑动：</p>\n<ul>\n<li><p>低序号的分组到来，接收窗口移动。</p>\n</li>\n<li><p>高序号分组乱序到来时，缓存但是不交付，因为要保证有序，必须等待低序号的分组到来。</p>\n</li>\n</ul>\n<h4 id=\"正常情况下两个窗口的互动\"><a href=\"#正常情况下两个窗口的互动\" class=\"headerlink\" title=\"正常情况下两个窗口的互动\"></a>正常情况下两个窗口的互动</h4><p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-89.png\"></p>\n<h3 id=\"GBN协议\"><a href=\"#GBN协议\" class=\"headerlink\" title=\"GBN协议\"></a>GBN协议</h3><p>发送端最多在流水线中有N个未确认的分组</p>\n<p>GBN协议 size &#x3D;&#x3D; 1只能顺序接收，且只能发送连续收到的最大的分组的确认</p>\n<p>接收端只是发送累计型确认，接收端如果发现gap，则不确认新到来的分组</p>\n<p>发送端拥有对最老的未确认分组的定时器。</p>\n<p>只需设置一个定时器，当定时器到时时，重传所有未确认的分组</p>\n<h4 id=\"异常情况下GBN的两个窗口互动\"><a href=\"#异常情况下GBN的两个窗口互动\" class=\"headerlink\" title=\"异常情况下GBN的两个窗口互动\"></a>异常情况下GBN的两个窗口互动</h4><p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-80.png\"></p>\n<h4 id=\"GBN的FSM\"><a href=\"#GBN的FSM\" class=\"headerlink\" title=\"GBN的FSM\"></a>GBN的FSM</h4><p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-82.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-83.png\"></p>\n<h4 id=\"GBN运行\"><a href=\"#GBN运行\" class=\"headerlink\" title=\"GBN运行\"></a>GBN运行</h4><p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-76.png\"></p>\n<h3 id=\"SR协议\"><a href=\"#SR协议\" class=\"headerlink\" title=\"SR协议\"></a>SR协议</h3><p>发送端最多在流水线中有N个未确认的分组</p>\n<p>SR协议 size &gt; 1则可以乱序接收，最终按顺序交付给上层</p>\n<p>接收方对每个到来的分组单独确认</p>\n<p>发送方为每个未确认的分组持有一个定时器</p>\n<p>当定时器超时后，重发未确认的分组</p>\n<h4 id=\"SR的运行\"><a href=\"#SR的运行\" class=\"headerlink\" title=\"SR的运行\"></a>SR的运行</h4><p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-77.png\"></p>\n<h4 id=\"异常情况下SR的两个窗口互动\"><a href=\"#异常情况下SR的两个窗口互动\" class=\"headerlink\" title=\"异常情况下SR的两个窗口互动\"></a>异常情况下SR的两个窗口互动</h4><p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-75.png\"></p>\n<h3 id=\"GBN与SR的异同和对比\"><a href=\"#GBN与SR的异同和对比\" class=\"headerlink\" title=\"GBN与SR的异同和对比\"></a>GBN与SR的异同和对比</h3><p>相同之处</p>\n<ul>\n<li><p>发送窗口 &gt; 1</p>\n</li>\n<li><p>一次能够发送多个未经确认的分组</p>\n</li>\n</ul>\n<p>不同之处</p>\n<ul>\n<li><p>GBN 接收窗口size &#x3D;&#x3D; 1</p>\n<ul>\n<li><p>接收端: 只能顺序接收</p>\n</li>\n<li><p>发送端: 从表现来看,一旦一个分组没有发成功,如: 0, 1, 2, 3, 4。假设1没成功，234都发出去了，要返回1再发送</p>\n</li>\n</ul>\n</li>\n<li><p>SR 接收窗口size &gt; 1</p>\n<ul>\n<li><p>接收端: 可以乱序接收</p>\n</li>\n<li><p>发送端: 发送0, 1, 2, 3, 4。一旦1未成功，234已发送，无需重发，选择性发送1</p>\n</li>\n</ul>\n</li>\n</ul>\n<p>对比</p>\n<ul>\n<li><p>GBN</p>\n<ul>\n<li><p>优点：简单，所需资源少（接收方一个缓存单元）</p>\n</li>\n<li><p>缺点：一旦出错，回退N步代价大</p>\n</li>\n<li><p>适用于出错率低的场景</p>\n</li>\n</ul>\n</li>\n<li><p>SR</p>\n<ul>\n<li><p>优点：出错时，重传一个代价小</p>\n</li>\n<li><p>缺点：复杂，所需资源多（接收方多个缓存单元）</p>\n</li>\n<li><p>适用于链路容量大（延迟大，带宽大），这种场景出错代价较大</p>\n</li>\n</ul>\n</li>\n</ul>\n<h2 id=\"3-5-面向连接的传输-TCP\"><a href=\"#3-5-面向连接的传输-TCP\" class=\"headerlink\" title=\"3.5 面向连接的传输 TCP\"></a>3.5 面向连接的传输 TCP</h2><ul>\n<li><p>点对点：一个发送方，一个接收方</p>\n</li>\n<li><p>可靠的、按顺序的字节流：没有报文边界</p>\n</li>\n<li><p>管道化（流水线）：TCP拥塞控制和流量控制设置窗口大小</p>\n</li>\n<li><p>发送和接收缓存</p>\n</li>\n<li><p>会对上层下传的数据根据Max Segment Size进行切分并加上TCP的头部</p>\n</li>\n<li><p>全双工数据：在同一连接中数据双向流动</p>\n</li>\n<li><p>面向连接：在数据交换前，通过握手初始化双方状态</p>\n</li>\n<li><p>有流量控制：发送方不会淹没接收方</p>\n</li>\n</ul>\n<h3 id=\"TCP报文段结构\"><a href=\"#TCP报文段结构\" class=\"headerlink\" title=\"TCP报文段结构\"></a>TCP报文段结构</h3><p>16bit源端口，16bit目标端口，32bit序号，32bit确认号，4bit首部长度，6bit保留未用，6bit标志位，16bit接收窗口，16bit校验和，16bit紧急数据指针（通常没用），头部可选项，数据部分</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-78.png\"></p>\n<h4 id=\"序号（对字节计数\"><a href=\"#序号（对字节计数\" class=\"headerlink\" title=\"序号（对字节计数\"></a>序号（对字节计数</h4><p>TCP的body部分的第一个字节在整个字节流中的offset</p>\n<p>假设第0块数据的地址是X，则第n块地址是X+n * MSS</p>\n<p>从X开始而不是从0、1开始是防止旧的滞留在网络的报文对现有的字节流产生影响</p>\n<h4 id=\"确认号（对字节计数\"><a href=\"#确认号（对字节计数\" class=\"headerlink\" title=\"确认号（对字节计数\"></a>确认号（对字节计数</h4><p>S发向R，则R要返回ACK。此处的ACK序号与之前的RDT、GBN、SR不同，例如ACK555，表示接收到了554字节以及554字节之前的所有的数据，期望从555字节开始的数据。（需要标志位ACK为1）</p>\n<h4 id=\"标志位\"><a href=\"#标志位\" class=\"headerlink\" title=\"标志位\"></a>标志位</h4><p>U：URG紧急数据（通常不用）</p>\n<p>A：ACK</p>\n<p>P：PSH马上推出数据（通常不用）</p>\n<p>R、S、F：RST，SYN，FIN 用于建立&#x2F;拆除连接</p>\n<h3 id=\"TCP往返延迟RTT和超时\"><a href=\"#TCP往返延迟RTT和超时\" class=\"headerlink\" title=\"TCP往返延迟RTT和超时\"></a>TCP往返延迟RTT和超时</h3><p>Q：怎样设置TCP超时</p>\n<p>A：比RTT要长，但是RTT是变化的。太早会导致不必要的重传，太晚会对报文段丢失反映太慢，消极</p>\n<p>Q：怎样估计RTT</p>\n<p>A：SampleRTT：测量从报文段发出到收到确认的时间。如果有重传，忽略此次测量。由于SampleRTT会变化，因此对最近的几个测量值取平均，估计的RTT会比较平滑</p>\n<h4 id=\"计算RTT\"><a href=\"#计算RTT\" class=\"headerlink\" title=\"计算RTT\"></a>计算RTT</h4><p>$$EstimatedRTT_{当前周期} &#x3D; (1 - \\alpha) * EstimatedRTT_{前一周期} + \\alpha * SampleRTT$$</p>\n<p>指数加权移动平均</p>\n<p>过去样本的影响呈指数衰减</p>\n<p>推荐值为 $$\\alpha &#x3D; 0.125$$</p>\n<h4 id=\"设置超时\"><a href=\"#设置超时\" class=\"headerlink\" title=\"设置超时\"></a>设置超时</h4><p>EstimatedRTT + 安全边界时间</p>\n<p>EstimatedRTT变化大(方差大) -&gt; 较大的安全边界时间</p>\n<p>SampleRTT会偏离EstimatedRTT多远:</p>\n<p>$$DevRTT &#x3D; (1-\\beta)*DevRTT + \\beta * |SampleRTT - EstimatedRTT|$$</p>\n<p>其中推荐值为 $$\\beta &#x3D; 0.25$$</p>\n<p>超时时间间隔为</p>\n<p>$$TimeoutInteval &#x3D; EstimatedRTT + 4 * DevRTT$$</p>\n<h3 id=\"可靠数据传输\"><a href=\"#可靠数据传输\" class=\"headerlink\" title=\"可靠数据传输\"></a>可靠数据传输</h3><p>TCP在IP不可靠服务的基础上建立了rdt(借鉴了GBN和SR的设计)</p>\n<ul>\n<li><p>管道化的报文段</p>\n</li>\n<li><p>累积确认</p>\n</li>\n<li><p>单个重传定时器</p>\n</li>\n<li><p>没有规范是否接收乱序</p>\n</li>\n</ul>\n<p>以下事件触发重传</p>\n<ul>\n<li><p>超时(只重发那个最早未确认的段)</p>\n</li>\n<li><p>重复的确认,在收到一个正确的确认后又收到三个冗余确认</p>\n</li>\n</ul>\n<h4 id=\"TCP发送方\"><a href=\"#TCP发送方\" class=\"headerlink\" title=\"TCP发送方\"></a>TCP发送方</h4><p>FSM: </p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-79.png\"></p>\n<p>发送方事件:</p>\n<p>从应用层接收数据:</p>\n<ul>\n<li><p>用nextseq创建报文段</p>\n</li>\n<li><p>序号nextseq为报文段首字节的字节流编号</p>\n</li>\n<li><p>如果还没有运行,启动定时器</p>\n</li>\n</ul>\n<p>超时:</p>\n<ul>\n<li><p>重传后沿最老的报文段</p>\n</li>\n<li><p>重新启动定时器</p>\n</li>\n</ul>\n<p>收到确认: </p>\n<ul>\n<li><p>更新已被确认的报文序号</p>\n</li>\n<li><p>如果当前还有未被确认的报文段,重新启动定时器</p>\n</li>\n</ul>\n<p>伪代码:</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-103.png\"></p>\n<h4 id=\"TCP重传\"><a href=\"#TCP重传\" class=\"headerlink\" title=\"TCP重传\"></a>TCP重传</h4><p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-104.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-101.png\"></p>\n<p>此外,如果校验出错,则视为丢失,等待超时重传</p>\n<p>产生TCP ACK的建议</p>\n<table>\n<thead>\n<tr>\n<th>接收方的事件</th>\n<th>TCP接收方动作</th>\n</tr>\n</thead>\n<tbody><tr>\n<td>所期望序号的报文段按序到达。所有在期望序号之前的数据都已经被确认</td>\n<td>延迟的ACK。对另一个按序报文段的到达最多等待500ms。如果下一个报文段在这个时间间隔内没有到达，则发送一个ACK。</td>\n</tr>\n<tr>\n<td>有期望序号的报文段到达。另一个按序报文段等待发送ACK</td>\n<td>立即发送单个累积ACK，以确认两个按序报文段。</td>\n</tr>\n<tr>\n<td>比期望序号大的报文段乱序到达。检测出数据流中的间隔</td>\n<td>立即发送重复的ACK，指明下一个期待字节的序号</td>\n</tr>\n<tr>\n<td>能部分或完全填充接收数据间隔的报文段到达。</td>\n<td>若该报文段起始于间隔（gap）的低端，则立即发送ACK。</td>\n</tr>\n</tbody></table>\n<h4 id=\"快速重传\"><a href=\"#快速重传\" class=\"headerlink\" title=\"快速重传\"></a>快速重传</h4><p>然而超时周期往往太长,在重传丢失报文段之前的延时太长</p>\n<p>因此通过重复的ACK来检测报文段丢失。</p>\n<p>发送方通常会连续发送大量报文段</p>\n<p>如果报文段丢失，通常会引起多个重复的ACK。</p>\n<p>如果发送方收到同一数据的3个容易ACK，则重传最小序号的段。</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-100.png\"></p>\n<p>伪代码：</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-99.png\"></p>\n<h3 id=\"流量控制\"><a href=\"#流量控制\" class=\"headerlink\" title=\"流量控制\"></a>流量控制</h3><p>如果另外整出来个单独的进行缓冲区大小的通信，就很麻烦很杂乱，因此使用捎带技术piggyback，使得对方得知我们的空闲缓冲区有多少</p>\n<p>TCP报文段中有接收窗口的大小，如果空闲缓冲区只有1024，则只能发最多1024的报文。</p>\n<h3 id=\"连接管理\"><a href=\"#连接管理\" class=\"headerlink\" title=\"连接管理\"></a>连接管理</h3><p> 在正式交换数据之前，发送方和接收方握手建立通信关系：</p>\n<ul>\n<li><p>同意建立连接（双方都知道对方愿意建立连接）</p>\n</li>\n<li><p>同意连接参数</p>\n</li>\n</ul>\n<h4 id=\"为什么不能两次握手建立连接\"><a href=\"#为什么不能两次握手建立连接\" class=\"headerlink\" title=\"为什么不能两次握手建立连接\"></a>为什么不能两次握手建立连接</h4><p>两次握手建立请求可行吗？</p>\n<ul>\n<li><p>变化的延迟</p>\n</li>\n<li><p>由于丢失造成的重传</p>\n</li>\n<li><p>报文乱序</p>\n</li>\n<li><p>互相看不到对方</p>\n</li>\n</ul>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-102.png\"></p>\n<h4 id=\"TCP三次握手建立连接\"><a href=\"#TCP三次握手建立连接\" class=\"headerlink\" title=\"TCP三次握手建立连接\"></a>TCP三次握手建立连接</h4><p>三次握手：</p>\n<ol>\n<li><p>客户端-&gt;服务器: 发送SYN和初始序列号X</p>\n</li>\n<li><p>服务器-&gt;客户端: 收到后回复SYN + ACK, 并携带自己的初始序列号Y</p>\n</li>\n<li><p>客户端-&gt;服务器: 收到后回复ACK, 表示确认建立连接</p>\n</li>\n</ol>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-96.png\"></p>\n<p>三次握手能够解决上述的两次握手的问题</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-93.png\"></p>\n<p>TCP三次握手的FSM：</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-94.png\"></p>\n<h4 id=\"TCP四次挥手关闭连接\"><a href=\"#TCP四次挥手关闭连接\" class=\"headerlink\" title=\"TCP四次挥手关闭连接\"></a>TCP四次挥手关闭连接</h4><p>客户端，服务器分别关闭自己这一侧的链接</p>\n<p>发送FIN标志位为1的TCP段</p>\n<p>一旦收到FIN，用ACK回应</p>\n<p>四次挥手: </p>\n<ol>\n<li><p>客户端-&gt;服务器: 发送链接拆除的请求FIN</p>\n</li>\n<li><p>服务器-&gt;客户端: 发送链接拆除的确认ACK。之后，客户端不能再向服务器发送数据</p>\n</li>\n<li><p>服务器-&gt;客户端: 发送链接拆除的请求FIN</p>\n</li>\n<li><p>客户端-&gt;服务器: 发送链接拆除的确认ACK。之后，服务器不能再向客户端发送数据</p>\n</li>\n</ol>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-95.png\"></p>\n<h2 id=\"3-6-拥塞控制原理\"><a href=\"#3-6-拥塞控制原理\" class=\"headerlink\" title=\"3.6 拥塞控制原理\"></a>3.6 拥塞控制原理</h2><h3 id=\"拥塞\"><a href=\"#拥塞\" class=\"headerlink\" title=\"拥塞\"></a>拥塞</h3><ul>\n<li><p>非正式的定义：有太多数据需要网络传输，超过了网络的处理能力</p>\n</li>\n<li><p>与流量控制不同</p>\n</li>\n<li><p>拥塞的表现</p>\n<ul>\n<li><p>分组丢失（路由器缓冲区溢出）</p>\n</li>\n<li><p>分组经历比较长的延迟（在路由器的队列中排队）</p>\n</li>\n</ul>\n</li>\n<li><p>网络中TOP10的问题</p>\n</li>\n</ul>\n<h3 id=\"拥塞的原理和代价：场景1\"><a href=\"#拥塞的原理和代价：场景1\" class=\"headerlink\" title=\"拥塞的原理和代价：场景1\"></a>拥塞的原理和代价：场景1</h3><ul>\n<li><p>两个发送端，两个接收端</p>\n</li>\n<li><p>一个路由器，具有无限大的缓冲</p>\n</li>\n<li><p>输出链路带宽为：$$R$$，输入速率为$$\\lambda_{in}$$，输出速率为$$\\lambda_{out}$$</p>\n</li>\n<li><p>没有重传</p>\n</li>\n</ul>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-92.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-97.png\"></p>\n<h4 id=\"拥塞的代价\"><a href=\"#拥塞的代价\" class=\"headerlink\" title=\"拥塞的代价\"></a>拥塞的代价</h4><p>流量强度越大，延时就越大，流量强度趋近于1时，延时趋近于无限大</p>\n<h3 id=\"拥塞的原理和代价：场景2\"><a href=\"#拥塞的原理和代价：场景2\" class=\"headerlink\" title=\"拥塞的原理和代价：场景2\"></a>拥塞的原理和代价：场景2</h3><ul>\n<li><p>一个路由器，有限的缓冲</p>\n</li>\n<li><p>分组丢失时，发送端重传</p>\n<ul>\n<li><p>应用层的输入&#x3D;应用层输出: $$\\lambda_{in} &#x3D; \\lambda_{out}$$</p>\n</li>\n<li><p>传输层的输入包括重传: $$\\lambda^{‘}<em>{in} &gt;&#x3D; \\lambda</em>{in}$$</p>\n</li>\n</ul>\n</li>\n</ul>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-91.png\"></p>\n<h4 id=\"理想化-发送端有完美的信息\"><a href=\"#理想化-发送端有完美的信息\" class=\"headerlink\" title=\"理想化: 发送端有完美的信息\"></a>理想化: 发送端有完美的信息</h4><p>发送端知道什么时候路由器的缓冲是可用的, 这样发送端只会在缓冲可用时发送, 不会产生丢失。$$\\lambda^{‘}<em>{in} &#x3D; \\lambda</em>{in}$$</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-98.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-90.png\"></p>\n<h4 id=\"理想化-掌握丢失信息\"><a href=\"#理想化-掌握丢失信息\" class=\"headerlink\" title=\"理想化: 掌握丢失信息\"></a>理想化: 掌握丢失信息</h4><p>分组可以丢失，在路由器由于缓冲区满而被丢弃</p>\n<p>如果知道分组丢失了，发送方重传分组</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-117.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-119.png\"></p>\n<h4 id=\"现实-重复\"><a href=\"#现实-重复\" class=\"headerlink\" title=\"现实: 重复\"></a>现实: 重复</h4><p>分组可能丢失，由于缓冲区满而被丢弃</p>\n<p>发送端最终超时，发送第二个拷贝，两个分组都被发出</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-115.png\"></p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-118.png\"></p>\n<p>输出比输入少的原因：</p>\n<ol>\n<li><p>重传丢失的分组</p>\n</li>\n<li><p>没有必要重传的重复分组</p>\n</li>\n</ol>\n<h4 id=\"拥塞的代价-1\"><a href=\"#拥塞的代价-1\" class=\"headerlink\" title=\"拥塞的代价\"></a>拥塞的代价</h4><ul>\n<li><p>为了达到一个有效的输出，网络需要做更多的工作（重传）</p>\n</li>\n<li><p>没有必要的重传，使得链路中包含了多个分组的拷贝</p>\n<ul>\n<li><p>没有丢失，但是在拥塞状态下经历的时间比较长（超时）的分组</p>\n</li>\n<li><p>降低了的goodput</p>\n</li>\n</ul>\n</li>\n</ul>\n<h3 id=\"拥塞的原理和代价-场景3\"><a href=\"#拥塞的原理和代价-场景3\" class=\"headerlink\" title=\"拥塞的原理和代价: 场景3\"></a>拥塞的原理和代价: 场景3</h3><ul>\n<li><p>四个发送端</p>\n</li>\n<li><p>多重路径</p>\n</li>\n<li><p>超时&#x2F;重传</p>\n</li>\n</ul>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-116.png\"></p>\n<p>Q: 当$$\\lambda^{‘}<em>{in}$$,$$\\lambda</em>{in}$$增加时,会发生什么?</p>\n<p>A: 当红色的$$\\lambda^{‘}_{in}$$增加时,所有到来的蓝色分组都在最上方的队列中被丢弃了,蓝色吞吐量趋近于0。</p>\n<h4 id=\"又一个拥塞的代价\"><a href=\"#又一个拥塞的代价\" class=\"headerlink\" title=\"又一个拥塞的代价\"></a>又一个拥塞的代价</h4><p>当分组丢失时，任何“关于这个分组的上游传输能力”都被浪费了</p>\n<h3 id=\"拥塞的代价总结\"><a href=\"#拥塞的代价总结\" class=\"headerlink\" title=\"拥塞的代价总结\"></a>拥塞的代价总结</h3><ol>\n<li><p>流量强度越大，延时就越大，流量强度趋近于1时，延时趋近于无限大</p>\n</li>\n<li><p>为了达到一个有效的输出，网络需要做更多的工作（重传）</p>\n</li>\n<li><p>没有必要的重传，使得链路中包含了多个分组的拷贝</p>\n</li>\n<li><p>当分组丢失时，任何“关于这个分组的上游传输能力”都被浪费了</p>\n</li>\n</ol>\n<h3 id=\"拥塞控制的方法\"><a href=\"#拥塞控制的方法\" class=\"headerlink\" title=\"拥塞控制的方法\"></a>拥塞控制的方法</h3><h4 id=\"端到端拥塞控制\"><a href=\"#端到端拥塞控制\" class=\"headerlink\" title=\"端到端拥塞控制\"></a>端到端拥塞控制</h4><ul>\n<li><p>没有来自网络的显式反馈</p>\n</li>\n<li><p>端系统根据延迟和丢失时间判断是否有拥塞</p>\n</li>\n<li><p>TCP采用该方法</p>\n</li>\n</ul>\n<h4 id=\"网络辅助的拥塞控制\"><a href=\"#网络辅助的拥塞控制\" class=\"headerlink\" title=\"网络辅助的拥塞控制\"></a>网络辅助的拥塞控制</h4><p>路由器提供给端系统反馈信息</p>\n<ul>\n<li><p>单个bit位，显示有拥塞（SNA，DECbit，TCP&#x2F;IP，ATM）</p>\n</li>\n<li><p>显式提供发送端可以采用的速率</p>\n</li>\n</ul>\n<h3 id=\"案例-ATM-ABR拥塞控制\"><a href=\"#案例-ATM-ABR拥塞控制\" class=\"headerlink\" title=\"案例: ATM ABR拥塞控制\"></a>案例: ATM ABR拥塞控制</h3><h4 id=\"ATM网络介绍\"><a href=\"#ATM网络介绍\" class=\"headerlink\" title=\"ATM网络介绍\"></a>ATM网络介绍</h4><p>ATM（Asynchronous Transfer Mode，异步传输模式）是一种融合了电路交换和分组交换特点的网络技术，曾被认为是非常有前景的网络架构，目前虽然未在广泛网络环境中普及，但仍在一些专用网络中（如银行系统）得到应用。</p>\n<ul>\n<li><p>数据传输单元为“信元”（Cell）： 每个信元长度固定为 53 字节，其中 5 字节为头部，48 字节为数据部分。</p>\n</li>\n<li><p>固定长度小分组： 信元较小且长度固定，因此在交换节点进行存储转发的时间短，易于控制。</p>\n</li>\n<li><p>低延迟：</p>\n<ul>\n<li><p>电路交换的延迟为 1 bit；</p>\n</li>\n<li><p>分组交换的延迟为一个完整分组；</p>\n</li>\n<li><p>ATM 信元介于两者之间，因其长度小于传统分组但大于 1 bit。</p>\n</li>\n</ul>\n</li>\n<li><p>迟稳定、易于调度： 由于信元长度固定，延迟较为可控。</p>\n</li>\n<li><p>综合特性： 同时具备电路交换的低延迟优势和分组交换的灵活性。</p>\n</li>\n</ul>\n<h4 id=\"ABR模式\"><a href=\"#ABR模式\" class=\"headerlink\" title=\"ABR模式\"></a>ABR模式</h4><p>ABR 是 ATM 网络中的一种服务类型，提供“弹性服务”：</p>\n<ul>\n<li><p>轻载时： 可以尽可能使用网络带宽；</p>\n</li>\n<li><p>拥塞时： 发送方必须将发送速率限制在预先设定的“最小保障速率”上。</p>\n</li>\n<li><p>这些控制机制由交换机实现</p>\n</li>\n</ul>\n<p>在ATM网络中有两种信元：数据信元(data cell)和资源信元(RM cell)</p>\n<p>RM 信元的工作原理：</p>\n<ul>\n<li><p>发送端在数据流中定期插入 RM 信元；</p>\n</li>\n<li><p>经过的交换机会根据当前网络状况对 RM 信元中的字段进行设置；</p>\n</li>\n<li><p>RM 信元到达接收端后，接收端原样返回给发送端；</p>\n</li>\n<li><p>发送端根据返回的 RM 信元内容调整自己的发送速率。</p>\n</li>\n</ul>\n<p>RM 信元中的关键字段：</p>\n<ul>\n<li><p>NI 位（No Increase）： 表示网络轻微拥塞，发送速率不应继续增加；</p>\n</li>\n<li><p>CI 位（Congestion Indication）： 表示网络已发生拥塞；</p>\n</li>\n<li><p>ER 字段（Explicit Rate）： 表示交换机建议的明确发送速率（可能降低，不会提高）。</p>\n</li>\n</ul>\n<p>其他相关机制：</p>\n<ul>\n<li><p>EFC位于普通数据信元中；</p>\n<ul>\n<li><p>拥塞的交换机会将其设置为 1；</p>\n</li>\n<li><p>接收端若检测到前序数据信元的 EFCI 位为 1，则在返回的 RM 信元中设置 CI 位。</p>\n</li>\n</ul>\n</li>\n</ul>\n<h2 id=\"3-7-TCP拥塞控制\"><a href=\"#3-7-TCP拥塞控制\" class=\"headerlink\" title=\"3.7 TCP拥塞控制\"></a>3.7 TCP拥塞控制</h2><h3 id=\"端到端的拥塞控制机制\"><a href=\"#端到端的拥塞控制机制\" class=\"headerlink\" title=\"端到端的拥塞控制机制\"></a>端到端的拥塞控制机制</h3><ul>\n<li><p>路由器不向发送主机有关拥塞的反馈信息</p>\n<ul>\n<li><p>路由器的负担较轻</p>\n</li>\n<li><p>符合网络核心简单的TCP&#x2F;IP架构原则</p>\n</li>\n</ul>\n</li>\n<li><p>端系统根据自身得到的信息，判断是否发生拥塞，从而采取动作</p>\n</li>\n</ul>\n<h3 id=\"拥塞控制的问题\"><a href=\"#拥塞控制的问题\" class=\"headerlink\" title=\"拥塞控制的问题\"></a>拥塞控制的问题</h3><ol>\n<li><p>如何检测拥塞</p>\n<ol>\n<li><p>轻微拥塞</p>\n</li>\n<li><p>拥塞</p>\n</li>\n</ol>\n</li>\n<li><p>控制策略</p>\n<ol>\n<li><p>在拥塞发生时，降低速率</p>\n<ol>\n<li><p>轻微拥塞，如何降低</p>\n</li>\n<li><p>拥塞，如何降低</p>\n</li>\n</ol>\n</li>\n<li><p>在拥塞缓解时，增加速率</p>\n</li>\n</ol>\n</li>\n</ol>\n<h3 id=\"拥塞感知\"><a href=\"#拥塞感知\" class=\"headerlink\" title=\"拥塞感知\"></a>拥塞感知</h3><p>发送端如何感知拥塞？</p>\n<h4 id=\"某个段超时了（丢失事件）：拥塞\"><a href=\"#某个段超时了（丢失事件）：拥塞\" class=\"headerlink\" title=\"某个段超时了（丢失事件）：拥塞\"></a>某个段超时了（丢失事件）：拥塞</h4><p>超过一定时间后，某个段的确认没有来</p>\n<p>原因1：网络拥塞（某个路由器缓冲区没空间了，被丢弃）概率大</p>\n<p>原因2：出错被丢弃了（各级错误，没有通过校验，被丢弃）概率小</p>\n<p>一旦超时，就视为拥塞，尽管可能会误判（原因2），但是小概率的误判可以接受，总体的控制方向是对的。</p>\n<h4 id=\"有关某个段的3次重复ACK：轻微拥塞\"><a href=\"#有关某个段的3次重复ACK：轻微拥塞\" class=\"headerlink\" title=\"有关某个段的3次重复ACK：轻微拥塞\"></a>有关某个段的3次重复ACK：轻微拥塞</h4><p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-109.png\"></p>\n<p>第一个ACK，正常，确认绿段，期待红段</p>\n<p>第二个ACK，意味着蓝段乱序到达。</p>\n<p>第二三四个ACK重复，意味着红段之后的三个段都乱序到达了，红段丢失的可能性很大。</p>\n<p>网络此时还能进行一定程度的传输，拥塞的情况比第一种好。</p>\n<h3 id=\"如何控制发送端发送的速率\"><a href=\"#如何控制发送端发送的速率\" class=\"headerlink\" title=\"如何控制发送端发送的速率\"></a>如何控制发送端发送的速率</h3><p>发送端持有一个拥塞窗口的值：CongWin</p>\n<p>发送端限制已发送但是未确认的数据量的上限：</p>\n<p>$$LastByteSent - LastByteAcked &lt;&#x3D; CongWin$$</p>\n<p>从而粗略地控制发送方王网络注入的速率</p>\n<p>$$rate \\approx \\frac{CongWin}{RTT} \\  Byte&#x2F;sec$$</p>\n<p>CongWin是动态的,是感知到的网络拥塞的函数</p>\n<ul>\n<li><p>超时或者三个重复ACK, CongWin减少</p>\n<ul>\n<li><p>超时: CongWin降为1MSS,进入SS阶段然后倍增到CongWin&#x2F;2,从而进入CA阶段</p>\n</li>\n<li><p>三个重复ACK: CongWin降到CongWin&#x2F;2, 然后进入CA阶段</p>\n</li>\n</ul>\n</li>\n<li><p>否则(正常收到ACK): CongWin增加</p>\n</li>\n<li><p>SS阶段:加倍增加(每个RTT)</p>\n</li>\n<li><p>CA阶段:线性增加(每个RTT)</p>\n</li>\n</ul>\n<h3 id=\"TCP拥塞控制和流量控制的联合控制\"><a href=\"#TCP拥塞控制和流量控制的联合控制\" class=\"headerlink\" title=\"TCP拥塞控制和流量控制的联合控制\"></a>TCP拥塞控制和流量控制的联合控制</h3><p>发送端控制发送但是未确认的量同时也不能超过接收窗口 ,满足流量控制要求</p>\n<p>$$SendWin &#x3D; min\\left{CongWin, RecvWin\\right}$$</p>\n<p>同时满足拥塞控制和流量控制的要求</p>\n<h3 id=\"拥塞控制策略\"><a href=\"#拥塞控制策略\" class=\"headerlink\" title=\"拥塞控制策略\"></a>拥塞控制策略</h3><ul>\n<li><p>慢启动</p>\n</li>\n<li><p>AIMD: 线性增加 乘性减少</p>\n</li>\n<li><p>超时时间后的保守策略</p>\n</li>\n</ul>\n<h4 id=\"慢启动\"><a href=\"#慢启动\" class=\"headerlink\" title=\"慢启动\"></a>慢启动</h4><p>连接杠建立,CongWin &#x3D; 1MSS</p>\n<p>如果MSS &#x3D; 1460Byte &amp; RTT &#x3D; 200msec 则 初始速率 &#x3D; 58.4kbps</p>\n<p>而可用带宽可能远大于MSS&#x2F;RTT。因此应该尽快加速，到达希望的速率。</p>\n<p>当连接开始时，指数性增加发送速率，直到发生丢失的事件。</p>\n<p>慢启动的运行：</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-108.png\"></p>\n<p>当连接开始时，指数性增加（每个RTT）发送速率直到发生丢失事件</p>\n<ul>\n<li><p>每一个RTT，CongWin加倍</p>\n</li>\n<li><p>每收到一个ACK时，CongWin加一</p>\n</li>\n<li><p>慢启动阶段，只要不超时或者3个重复ACK，一个RTT，CongWin加倍。</p>\n</li>\n</ul>\n<p>总结：初始速率很慢，但是加速却是指数性的。从长期来看，指数增加，SS时间很短可以忽略。</p>\n<h4 id=\"AIMD-线性增加-乘性减少\"><a href=\"#AIMD-线性增加-乘性减少\" class=\"headerlink\" title=\"AIMD: 线性增加 乘性减少\"></a>AIMD: 线性增加 乘性减少</h4><p>超时: CongWin降为1MSS, 进入指数倍增阶段然后倍增到CongWin&#x2F;2, 从而进入线性增加阶段</p>\n<p>三个重复ACK: CongWin降到CongWin&#x2F;2, 然后进入线性增加阶段</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-113.png\"></p>\n<h4 id=\"什么时候将指数性增长变成线性？\"><a href=\"#什么时候将指数性增长变成线性？\" class=\"headerlink\" title=\"什么时候将指数性增长变成线性？\"></a>什么时候将指数性增长变成线性？</h4><p>在超时之前，当CongWin变成上次发生超时的窗口的一半</p>\n<p>实现：警戒值Threshold</p>\n<p>出现丢失时，将Threshold设置为CongWin的二分之一</p>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-107.png\"></p>\n<h4 id=\"总结\"><a href=\"#总结\" class=\"headerlink\" title=\"总结\"></a>总结</h4><ul>\n<li><p>当CongWin &lt; Threshold，发送端处于慢启动阶段（slow-start），窗口指数性增长。</p>\n</li>\n<li><p>当CongWin &gt; Threshold，发送端处于拥塞避免阶段（CA），窗口线性增长</p>\n</li>\n<li><p>当收到三个重复ACK，Threshold设置为CongWin &#x2F; 2，CongWin&#x3D;threshold + 3</p>\n</li>\n<li><p>当发生超时Timeout时，Threshold &#x3D; CongWin &#x2F; 2，CongWin &#x3D; 1MSS，进入SS阶段</p>\n</li>\n</ul>\n<table>\n<thead>\n<tr>\n<th>事件</th>\n<th>状态</th>\n<th>TCP发送端行为</th>\n<th>解释</th>\n</tr>\n</thead>\n<tbody><tr>\n<td>以前没有收到ACK的Data被ACKed</td>\n<td>慢启动SS</td>\n<td>CongWin &#x3D; CongWin + MSSif (CongWin &gt; Threshold)</td>\n<td>每一个RTT CongWin加倍</td>\n</tr>\n<tr>\n<td>以前没有收到ACK的data被ACKed</td>\n<td>拥塞避免CA</td>\n<td>CongWin &#x3D; CongWin + MSS * (MSS &#x2F; CongWin)</td>\n<td>加性增加, 每一个RTT对CongWin 加一个1 MSS</td>\n</tr>\n<tr>\n<td>通过收到3个重复的ACK，发现丢失的事件</td>\n<td>SS or CA</td>\n<td>Threshold &#x3D; CongWin&#x2F;2, CongWin &#x3D; Threshold+3, 状态变成“CA”</td>\n<td>快速重传, 实现乘性的减. CongWin没有变成1 MSS.</td>\n</tr>\n<tr>\n<td>超时</td>\n<td>SS or CA</td>\n<td>Threshold &#x3D; CongWin&#x2F;2, CongWin &#x3D; 1 MSS, 状态变成“SS”</td>\n<td>进入slow start</td>\n</tr>\n<tr>\n<td>重复的ACK</td>\n<td>SS or CA</td>\n<td>对被ACKed 的segment， 增 加重复ACK的计数</td>\n<td>CongWin and Threshold 不变</td>\n</tr>\n</tbody></table>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-111.png\"></p>\n<h3 id=\"TCP吞吐量\"><a href=\"#TCP吞吐量\" class=\"headerlink\" title=\"TCP吞吐量\"></a>TCP吞吐量</h3><p>使用窗口window尺寸W和RTT来描述，忽略慢启动阶段，假设发送端总有数据传输</p>\n<p>$$TCPthruput_{avg} &#x3D; \\frac{3W}{4RTT}\\ Bytes&#x2F;sec$$</p>\n<h3 id=\"TCP公平性\"><a href=\"#TCP公平性\" class=\"headerlink\" title=\"TCP公平性\"></a>TCP公平性</h3><p>公平性目标：如果K个TCP会话分享一个链路带宽为R的瓶颈，每一个会话的有效带宽为R&#x2F;K</p>\n<p>两个竞争的TCP会话：</p>\n<ul>\n<li><p>加性增加，斜率为1，吞吐量增加</p>\n</li>\n<li><p>乘性减少，吞吐量比例减少</p>\n</li>\n</ul>\n<p><img src=\"/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-114.png\"></p>\n<ol>\n<li><p>假设处开始时，x &gt; y，连接1的吞吐量 &gt; 连接2</p>\n</li>\n<li><p>然后加性增加，斜率为1, 吞吐量增加（x和y都+1MSS，所以斜率为1）</p>\n</li>\n<li><p>当超出边界之后，发生了丢失，乘性减，吞吐量比例减少（此时x超出了，要乘性减）</p>\n</li>\n<li><p>最后一直趋近到了 x &#x3D; y</p>\n</li>\n</ol>\n","categories":[],"tags":[{"name":"计算机网络","slug":"计算机网络","count":8,"path":"api/tags/计算机网络.json"}]}