{"title":"计算机网络（中科大）_Chapter3","slug":"计算机网络（中科大）_Chapter3","date":"2025-03-31T07:09:32.000Z","updated":"2025-03-31T09:13:49.967Z","comments":true,"path":"api/articles/计算机网络（中科大）_Chapter3.json","photos":[],"excerpt":"第三章 传输层在网络通信中，传输层是连接网络层与应用层之间的桥梁。它不仅负责实现端到端的进程通信，更要保障数据传输的可靠性、有序性与效率。无论是浏览网页、传输文件，还是观看视频、进行在线游戏，传输层都发挥着至关重要的作用。本章将深入剖析传输层的核心机制，包括多路复用与解复用、UDP与TCP协议的结构与特点、可靠数据传输的设计原理、流量控制、连接管理，以及拥塞控制的策略与实现。此外，还将介绍经典的滑动窗口协议和TCP拥塞控制算法，帮助读者从理论与实践两方面全面掌握传输层的工作原理与技术细节。","covers":["/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/Cover.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-46.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-52.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-72.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-74.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-71.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-70.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-69.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-66.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-67.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-73.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-65.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-62.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-68.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-60.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-63.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-64.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-61.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-88.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-87.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-86.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-85.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-84.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-81.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-89.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-80.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-82.png","/../Asset/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C%EF%BC%88%E4%B8%AD%E7%A7%91%E5%A4%A7%EF%BC%89_Chapter3/image-83.png","/../Asset/%E8%AE%A1%E7%AE%